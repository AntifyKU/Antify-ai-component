# Local artifacts
results/
# Exclude models/ — Cloud Build clones WITHOUT Git LFS, so COPY would copy the LFS
# pointer file (a tiny text file starting with "version https://git-lfs...") instead of
# the real binary. This causes torch.load to fail with "invalid load key, 'v'".
# The real model is downloaded from GCS at startup via MODEL_GCS_PATH env var.
models/
